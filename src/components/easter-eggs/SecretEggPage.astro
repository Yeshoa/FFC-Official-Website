---
import EggTrigger from '@components/easter-eggs/EggTrigger.astro';
import App from '@layouts/App.astro';
import EggJutsa from '@images/eggs/egg-jut.webp';
import type { EasterEggId } from '@config/easter-eggs';

interface Props {
  eggId: EasterEggId;
  title?: string;
}

const { eggId, title = 'FFC - Secret Egg' } = Astro.props;
---

<App title={title}>
  <section class="mx-auto flex min-h-[calc(100vh-72px)] w-full max-w-4xl items-center justify-center px-4 py-16">
    <div class="w-full max-w-2xl rounded-[2rem] border border-green-700/70 bg-green-950/85 p-8 text-center shadow-2xl sm:p-12">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.28em] text-green-300">Hidden Route</p>
      <h1 class="mb-4 text-4xl font-black leading-tight text-white sm:text-5xl">You found a secret page.</h1>
      <p class="mx-auto mb-10 max-w-xl text-base leading-relaxed text-green-100 sm:text-lg">
        This page is not linked anywhere. The egg is yours if you know what to do next.
      </p>

      <div class="flex justify-center">
        <EggTrigger
          eggId={eggId}
          image={EggJutsa}
          alt="Secret Easter egg"
          ariaLabel="Claim the secret route Easter egg"
          buttonClass="transition duration-300 hover:scale-105 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-green-300"
          imageClass="w-28 sm:w-32"
        />
      </div>
    </div>
  </section>
</App>
