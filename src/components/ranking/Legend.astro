    <!-- Intro banner -->
      <p class="text-sm text-green-200 text-center">
        Your <strong>Total Score</strong> combines roleplay, events, bonuses, and past performance with decay.
        <br />
        Higher scores mean higher chances to win and better seeding!
      </p>
