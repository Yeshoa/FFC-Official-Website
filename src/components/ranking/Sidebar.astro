---
import { SCORING_CONFIG } from '@lib/scoreUtils';
import Arrow from '@images/icons/arrow-up-right-from-square-solid.svg';
import { getCurrentEvents } from '@lib/eventUtils';
import { getCurrentRoleplays } from '@lib/roleplayUtils';
import { getCurrentBonuses } from '@lib/bonusUtils';
import Button from '@components/Button.astro';
import { ROUTES } from '@config/routes';

const currentEvents = getCurrentEvents();
const currentRoleplays = getCurrentRoleplays();
const currentBonuses = getCurrentBonuses();
---

<aside class="shrink-0 opacity-0 animate-[slide-in_1s_ease-in-out_forwards_.5s]">
  <div class="bg-green-900/30 border border-green-700/30 rounded-lg p-4 text-sm items-center">
    <h3 class="text-green-300 font-semibold text-xs uppercase tracking-wider mb-3">
      Scoring Guide
    </h3>

    <!-- Roleplay -->
    <div class="border-b border-green-700/40 py-3">
      <p class="text-xs font-semibold text-green-100 uppercase tracking-wider mb-1.5">Roleplay</p>
      <div class="space-y-1">
        {currentRoleplays.map(rp => (
          <div class="flex items-baseline justify-between gap-2">
            {/* <strong class="text-green-100">{rp.code || rp.name.slice(0, 4)}</strong> */}
            <strong class="text-green-300">{rp.name}</strong>
            <span class="text-green-500 text-xs shrink-0">{SCORING_CONFIG.RP_MAX}</span>
          </div>
          <p class="text-xs text-green-500 mt-0.5 whitespace-pre-line">{rp.description || ''}</p>
        ))}
      </div>
    </div>
    
    <!-- Events -->
    <div class="border-b border-green-700/40 py-3">
      <p class="text-xs font-semibold text-green-100 uppercase tracking-wider mb-1.5">Events</p>
      <div class="space-y-1">
        {currentEvents.map(event => (
          <div class="flex items-baseline justify-between gap-2">
              {event.link ? (
                <a href={event.link} target="_blank" class="text-green-200 hover:text-blue-300 transition-colors">
                  <strong>{event.name}</strong>
                  <Arrow class="inline w-2.5 h-2.5 fill-green-400 ml-0.5 mb-0.5" />
                </a>
              ) : (
                <strong class="text-green-200">{event.name}</strong>
              )}
            <span class="text-green-500 text-xs shrink-0">{SCORING_CONFIG.EV_MAX}</span>
          </div>
          // <p class="text-xs text-green-500 mt-0.5 whitespace-pre-line">{event.description || ''}</p>
        ))}
      </div>
    </div>
    
    <!-- Bonus -->
    <div class="border-b border-green-700/40 py-3">
      <p class="text-xs font-semibold text-green-100 uppercase tracking-wider mb-1.5">Bonus</p>
      <div class="space-y-1">
        {currentBonuses.map(bonus => (
          <div class="flex items-baseline justify-between gap-2">
            <strong class="text-green-200">{bonus.name}</strong>
            <span class="text-green-500 text-xs shrink-0">
              {bonus.maxScore !== 1 ? bonus.maxScore : SCORING_CONFIG.BO_MAX}
            </span>
          </div>
        <p class="text-xs text-green-500 mt-0.5 whitespace-pre-line">{bonus.description || ''}</p>
      ))}
      </div>
    </div>
    
    <!-- Past Performance -->
    <!-- <div class="border-b border-green-700/40 py-3">
      <p class="text-xs font-semibold text-green-100 uppercase tracking-wider mb-1.5">Past</p>
      <div class="space-y-1">
        {[
          { code: 'RP', name: 'Roleplay' },
          { code: 'Ev', name: 'Events' },
          { code: 'Bn', name: 'Bonus' },
          { code: 'Res', name: 'Results' },
        ].map(item => (
          <div class="flex items-baseline justify-between gap-2">
            <strong class="text-green-200">{item.name}</strong>
            <span class="text-green-600 text-xs shrink-0 italic">decay</span>
          </div>
        ))}
      </div>
    </div> -->

    <!-- Decay summary -->
    {/* <div class="border-t border-green-700/40 pt-3 mb-3">
      <p class="text-xs text-green-500 font-medium mb-1">Decay rate</p>
      <div class="flex justify-between text-xs text-green-600">
        <span>-1 ed.</span><span class="text-green-300">100%</span>
      </div>
      <div class="flex justify-between text-xs text-green-600">
        <span>-2 ed.</span><span class="text-yellow-400/80">50%</span>
      </div>
      <div class="flex justify-between text-xs text-green-600">
        <span>-3 ed.</span><span class="text-orange-400/80">25%</span>
      </div>
      <div class="flex justify-between text-xs text-green-600">
        <span>-4 ed.</span><span class="text-red-400/80">10%</span>
      </div>
    </div> */}

    <!-- Link -->
    <div class="text-center mt-3">
      <Button link={ROUTES.articles.detail('ranking')})>
        Full Guide
      </Button>
    </div>
  </div>
</aside>
